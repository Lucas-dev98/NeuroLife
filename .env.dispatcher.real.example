# Copie para .env.dispatcher.real e preencha com credenciais reais.
# Nao versione o arquivo com segredos.

DISPATCH_CHANNEL_MODE=real
DISPATCHER_POLL_SECONDS=2
DISPATCHER_BATCH_SIZE=50
DISPATCH_FAIL_CHANNELS=

# Push (FCM HTTP v1 proxy/provider)
FCM_ENDPOINT=https://your-fcm-endpoint.example/messages:send
FCM_AUTH_BEARER=replace_with_real_bearer_token
FCM_DEFAULT_TOKEN=replace_with_real_device_token
FCM_TIMEOUT_SECONDS=8

# Email (SMTP)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USERNAME=replace_with_real_username
SMTP_PASSWORD=replace_with_real_password
SMTP_FROM=alerts@your-domain.com

# WhatsApp (provider HTTP)
WHATSAPP_API_URL=https://your-whatsapp-provider.example/messages
WHATSAPP_API_TOKEN=replace_with_real_whatsapp_token
WHATSAPP_DEFAULT_TO=5511999999999
WHATSAPP_TIMEOUT_SECONDS=8
